# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=api.your-domain.com,localhost,127.0.0.1

# Browser origins allowed to call the API.
# Include your hosted frontend URL.
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com

# PostgreSQL
# Examples:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgresql://playto:playto@localhost:5432/playto

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
